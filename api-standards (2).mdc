              },
              {
                "key": "create",
                "name": "users.create",
                "label": "Create Users",
                "allowed": false
              }
            ]
          }
        ]
      },
      {
        "key": "products",
        "label": "Products",
        "order": 20,
        "groups": [
          {
            "key": "products.ai",
